  "db_name": "PostgreSQL",
  "query": "\n                select id, short_id, target, width, height, blurhash, appreciations_count, published_at\n                from photos\n                where owner_id = $1\n                  and published_at is not null\n                  and status = 'ready'\n                  and ($2::timestamptz is null or (published_at, id) < ($2, $3))\n                order by published_at desc, id desc\n                limit $4\n                ",
