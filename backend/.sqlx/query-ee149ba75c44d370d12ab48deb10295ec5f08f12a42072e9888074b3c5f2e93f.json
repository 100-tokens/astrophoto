{
  "db_name": "PostgreSQL",
  "query": "\n        select c.id, c.photo_id, c.author_id,\n               u.display_name as author_display_name,\n               c.body, c.created_at\n        from comments c\n        join users u on u.id = c.author_id\n        where c.photo_id = $1\n        order by c.created_at asc\n        ",
