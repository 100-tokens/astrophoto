  "db_name": "PostgreSQL",
  "query": "\n        select id, handle::text as \"handle!\", display_name, created_at,\n               (select count(*) from photos where owner_id = users.id and published_at is not null)\n                   as \"photo_count!\"\n          from users where handle = $1 and pending_deletion_at is null\n        ",
