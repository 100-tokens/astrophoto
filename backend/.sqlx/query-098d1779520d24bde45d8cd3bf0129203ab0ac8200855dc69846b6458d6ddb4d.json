  "query": "select si.role,\n                  ei.id, ei.kind, ei.canonical_name, ei.display_name,\n                  ei.brand, ei.model, ei.variant\n             from setup_items si\n             join equipment_items ei on ei.id = si.item_id\n            where si.setup_id = $1\n            order by si.role, ei.canonical_name",
