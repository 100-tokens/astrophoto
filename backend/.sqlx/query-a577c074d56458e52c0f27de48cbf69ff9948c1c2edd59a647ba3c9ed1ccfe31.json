  "query": "\n        select u.id as \"id!\", u.handle as \"handle!\", u.display_name as \"display_name!\"\n        from users u\n        where lower(u.handle) like $1 or lower(u.display_name) like $1\n        order by u.handle\n        limit $2\n        ",
