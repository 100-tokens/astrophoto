{
  "db_name": "PostgreSQL",
  "query": "\n        with inserted as (\n            insert into comments (photo_id, author_id, body)\n            values ($1, $2, $3)\n            returning id, photo_id, author_id, body, created_at\n        )\n        select i.id, i.photo_id, i.author_id,\n               u.display_name as author_display_name,\n               i.body, i.created_at\n        from inserted i\n        join users u on u.id = i.author_id\n        ",
