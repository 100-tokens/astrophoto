{
  "db_name": "PostgreSQL",
  "query": "\n        select c.id, c.photo_id, c.author_id,\n               coalesce(u.display_name, '[deleted]') as \"author_display_name!: String\",\n               c.body, c.created_at\n        from comments c\n        left join users u on u.id = c.author_id\n        where c.photo_id = $1\n        order by c.created_at asc\n        ",
