# Frontend dev environment.
# Copy to `frontend/.env.local` to override defaults when running `just dev`.
#
# When unset:
#   - The newer discovery client (`$lib/api/discoveryClient.ts`) defaults
#     `VITE_API_BASE_URL` to '' and emits relative URLs that hit the
#     SvelteKit dev origin (5173) and 404. Setting it to the backend
#     origin makes client-side fetches resolve correctly.
#   - The CDN module (`$lib/cdn.ts`) defaults `PUBLIC_CDN_BASE_URL` to
#     '/cdn'. The SvelteKit dev origin doesn't serve `/cdn`, so image
#     `<img src>` URLs 404 and tiles render broken. Pointing it at the
#     backend's `/cdn/img/<id>` route lets the local resize work.
#
# In prod, both vars are typically set per-environment (CloudFront for
# the CDN, the API gateway for the API) — these defaults are dev-only.

VITE_API_BASE_URL=http://localhost:8080
PUBLIC_CDN_BASE_URL=http://localhost:8080/cdn
