engine-strict=true
node-linker=hoisted
# pnpm 10 ignores build scripts of dependencies by default and exits non-zero
# when any are ignored. esbuild's postinstall fetches the native binary; this
# flag re-enables it (matches pre-10 behaviour). The pnpm.onlyBuiltDependencies
# allowlist in package.json is the more granular alternative but it didn't
# unblock --frozen-lockfile installs in our Koyeb build.
dangerously-allow-all-builds=true
