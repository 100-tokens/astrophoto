# Astrophoto local dev — copy to .env and edit if needed.

# --- Backend ---
APP_BIND=0.0.0.0:8080
APP_LOG=info
APP_DATABASE_URL=postgres://astrophoto:astrophoto@localhost:5434/astrophoto
APP_SESSION_SECURE=false           # true in prod (HTTPS only)
# REQUIRED in prod/staging (APP_SESSION_SECURE=true): the browser-facing
# frontend origin — feeds both the CORS allow-origin and the CSRF Origin
# allowlist. Unset in dev, it defaults to http://localhost:5173.
# APP_CORS_ORIGIN=http://localhost:5173
# Comma-separated additional browser-reachable frontend origins
# (e.g. a raw Koyeb *-web-* host alongside the canonical www).
# APP_EXTRA_BROWSER_ORIGINS=
# APP_PUBLIC_BASE_URL is the origin the backend embeds in outgoing email
# links (signup verification, password reset, email change, account
# deletion). End users click these from their inbox, so it MUST be the
# user-facing SvelteKit origin — NOT the backend origin.
APP_PUBLIC_BASE_URL=http://localhost:5173

# --- Storage (MinIO local; swap for R2 in prod) ---
APP_S3_ENDPOINT=http://localhost:9100
APP_S3_REGION=us-east-1
APP_S3_BUCKET=astrophoto
APP_S3_ACCESS_KEY=minioadmin
APP_S3_SECRET_KEY=minioadmin
APP_S3_PATH_STYLE=true             # MinIO requires path-style
APP_CDN_BASE_URL=http://localhost:8080/cdn

# --- OAuth (leave blank to disable Google login) ---
APP_OAUTH_GOOGLE_CLIENT_ID=
APP_OAUTH_GOOGLE_CLIENT_SECRET=
APP_OAUTH_GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/oauth/google/callback

# --- Mail (Phase 8a) ---
# Dev (MailHog): plaintext SMTP on port 1025, no auth.
# Prod (AWS SES): TLS on port 587, with SES SMTP credentials. Set APP_SMTP_TLS=true.
APP_SMTP_HOST=localhost
APP_SMTP_PORT=1025
APP_SMTP_TLS=false
APP_SMTP_USER=
APP_SMTP_PASS=
APP_MAIL_FROM=Astrophoto <noreply@astrophoto.local>

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080
PUBLIC_APP_NAME=Astrophoto
